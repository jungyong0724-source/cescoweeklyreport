<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">

  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700&display=swap" rel="stylesheet">

  <!-- ✅ QR 코드 생성 라이브러리 (qrcodejs) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

  <style>
    body { font-family: 'Noto Sans KR', sans-serif; background-color: #f8fafc; }
    .cesco-blue { background-color: #004d9d; }
    .fade-in { animation: fadeIn 0.4s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>

<body class="flex items-center justify-center min-h-screen p-4">
  <div class="bg-white p-8 rounded-3xl shadow-2xl w-full max-w-md border border-gray-100 fade-in">
    <div class="text-center mb-10">
      <div class="inline-block p-3 rounded-full bg-blue-50 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="Step 16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-gray-900 mb-2">나의 개인몰 URL</h1>
      <p class="text-gray-500 text-sm">사번을 입력하여 URL을 확인하고 복사하세요.</p>
    </div>

    <div class="space-y-5">
      <div>
        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 ml-1">Employee Number</label>
         <input type="text" id="empId" 
          inputmode="numeric" 
          pattern="[0-9]*" 
          placeholder="사번을 입력하세요" 
          class="w-full px-5 py-4 bg-gray-50 border-0 rounded-2xl focus:ring-2 focus:ring-blue-600 transition-all text-lg shadow-inner">
      </div>
      <button onclick="searchUrl()" id="searchBtn"
        class="w-full cesco-blue hover:bg-blue-800 text-white font-bold py-4 rounded-2xl transition-all shadow-lg active:scale-95">
        URL 조회하기
      </button>
    </div>

    <div id="resultArea" class="hidden mt-10 pt-8 border-t border-gray-100 fade-in">
      <div id="successContent" class="hidden">
        <p class="text-sm text-gray-500 mb-3 font-medium">조회된 개인몰 주소</p>

        <div class="bg-blue-50 p-4 rounded-xl border border-blue-100 mb-4 break-all">
          <span id="urlDisplay" class="text-blue-700 font-mono text-sm leading-relaxed"></span>
        </div>

        <button onclick="copyToClipboard()"
          class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-4 rounded-2xl transition-all flex items-center justify-center gap-2 shadow-md active:scale-95">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="Step 8 2a2 2 0 00-2 2v8a2 2 0 002 2h2v2a2 2 0 002 2h8a2 2 0 002-2V8a2 2 0 00-2-2h-2V4a2 2 0 00-2-2H8zM8 4h6v2H8V4zm2 10V8h8v8h-8v-2z" />
          </svg>
          URL 주소 복사하기
        </button>

        <!-- ✅ QR 코드 영역 -->
        <div class="mt-6">
          <p class="text-sm text-gray-500 mb-3 font-medium">QR 코드</p>
          <div class="bg-white p-4 rounded-xl border border-gray-200 flex items-center justify-center">
            <div id="qrWrap" class="flex items-center justify-center">
              <div id="qrcode" class="mb-6 flex justify-center"></div>
            </div>
          </div>

          <button onclick="downloadQr()"
          class="mt-4 w-full bg-slate-800 hover:bg-slate-900 text-white font-bold py-4 rounded-2xl transition-all flex items-center justify-center gap-2 shadow-md active:scale-95">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M3 14a1 1 0 011 1v1h12v-1a1 1 0 112 0v2a1 1 0 01-1 1H3a1 1 0 01-1-1v-2a1 1 0 011-1zm7-12a1 1 0 011 1v7.586l2.293-2.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L9 10.586V3a1 1 0 011-1z"/>
          </svg>
          QR 코드 다운로드
        </button>

        <p class="mt-3 text-xs text-gray-400 text-center leading-relaxed">
          모바일에서는 QR 이미지를 <span class="font-semibold text-gray-500">길게 눌러 저장</span>하실 수 있습니다.<br>
          일부 환경에서는 다운로드 대신 이미지가 새 탭으로 열릴 수 있습니다.
        </p>

          <p class="mt-2 text-xs text-gray-400">
            * 모바일 환경에 따라 다운로드 대신 이미지가 새 탭으로 열릴 수 있습니다.
          </p>
        </div>
      </div>

      <div id="errorContent" class="hidden text-center p-4 bg-red-50 rounded-xl border border-red-100">
        <p id="errorMessage" class="text-red-600 text-sm font-medium"></p>
      </div>
    </div>
  </div>

  <script>
    let lastUrl = "";
    let qrInstance = null;

    function searchUrl() {
      const empId = document.getElementById('empId').value;
      const btn = document.getElementById('searchBtn');
      const resultArea = document.getElementById('resultArea');
      const successContent = document.getElementById('successContent');
      const errorContent = document.getElementById('errorContent');

      if (!empId) {
        alert("사번을 입력해 주세요.");
        return;
      }

      btn.innerText = "조회 중...";
      btn.disabled = true;
      resultArea.classList.add('hidden');

      google.script.run
        .withSuccessHandler(function(url) {
        console.log("받아온 URL:", url); // URL이 잘 오는지 확인용
        
        if(!url) {
          alert("URL 정보가 비어있습니다.");
          return;
        }

        const qrcodeDiv = document.getElementById('qrcode');
        qrcodeDiv.innerHTML = ""; // 이전 내용 지우기

        // QR 코드 생성 시도
        try {
          new QRCode(qrcodeDiv, {
            text: url,
            width: 180,
            height: 180
          });
          console.log("QR 생성 성공!");
        } catch (e) {
          console.error("QR 생성 에러:", e);
        }

        document.getElementById('urlDisplay').innerText = url;
        resultArea.classList.remove('hidden');
        successContent.classList.remove('hidden');
        errorContent.classList.add('hidden');
        btn.innerText = "조회 및 QR 생성";
        btn.disabled = false;
      })
        .withFailureHandler(function(err) {
          // 중요: .innerText 대신 .innerHTML을 사용하여 링크를 활성화합니다.
          document.getElementById('errorMessage').innerHTML = err.message; 
          
          resultArea.classList.remove('hidden');
          successContent.classList.add('hidden');
          errorContent.classList.remove('hidden');
          btn.innerText = "조회 및 QR 생성";
          btn.disabled = false;
        })
        .getPersonalUrl(empId);
    }

    function copyToClipboard() {
      const urlText = document.getElementById('urlDisplay').innerText;
      if (!urlText) return;

      // 클립보드 API가 막히는 환경 대비(간단 fallback)
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(urlText).then(() => alert("성공적으로 복사되었습니다!"));
        return;
      }

      const ta = document.createElement("textarea");
      ta.value = urlText;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand("copy");
      document.body.removeChild(ta);
      alert("성공적으로 복사되었습니다!");
    }

    function renderQr(url) {
      const qrEl = document.getElementById("qrcode");
      qrEl.innerHTML = ""; // 이전 QR 제거

      // qrcodejs는 인스턴스를 따로 destroy가 없어서 DOM을 비우는 방식이 제일 깔끔
      qrInstance = new QRCode(qrEl, {
        text: url,
        width: 220,
        height: 220,
        correctLevel: QRCode.CorrectLevel.M
      });
    }

    function downloadQr() {
      if (!lastUrl) {
        alert("먼저 URL을 조회해 주세요.");
        return;
      }

      const qrEl = document.getElementById("qrcode");
      // qrcodejs는 환경에 따라 canvas 또는 img로 생성됨
      const canvas = qrEl.querySelector("canvas");
      const img = qrEl.querySelector("img");

      let dataUrl = "";
      if (canvas) dataUrl = canvas.toDataURL("image/png");
      else if (img && img.src) dataUrl = img.src;

      if (!dataUrl) {
        alert("QR 이미지를 찾을 수 없습니다. 다시 조회 후 시도해 주세요.");
        return;
      }

      const fileName = `cesco_personal_mall_qr_${(document.getElementById('empId').value || "").trim() || "unknown"}.png`;

      // 다운로드 트리거
      const a = document.createElement("a");
      a.href = dataUrl;
      a.download = fileName;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);

      // 일부 모바일/인앱 브라우저는 download 속성을 무시함 -> 새 탭 열기 fallback
      // (사용자에게 저장/공유하게끔)
      setTimeout(() => {
        // 다운로드가 막히면 새 탭에서 이미지가 열리도록 시도
        // (이미 다운로드가 됐다면 그냥 무시됨)
        try { window.open(dataUrl, "_blank"); } catch(e) {}
      }, 300);
    }
  </script>
</body>
</html>
