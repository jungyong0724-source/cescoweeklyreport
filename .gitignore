  ui.createMenu('AI 보고서 관리')
      .addItem('전체 데이터 동기화 업데이트 (전체 반영)', 'updateAllData')
      .addSeparator()
      .addItem('데이터 업데이트 (날씨/네이버/이슈/지표)', 'updateExternalData')
      .addItem('서치콘솔 주간비교 업데이트 (BQ)', 'updateGSCWeeklyData')
      .addItem('GA4 내부검색어 주간비교 업데이트 (BQ)', 'updateGA4WeeklyData')
      .addItem('GA4 핵심페이지 유입분석 (BQ)', 'updateGA4InboundWeeklyData')
      .addSeparator()
      .addItem('지난주 HTML 보고서 새롭게 작성하기', 'generateWeeklyReport')
      .addItem('작성된 보고서 다시 미리보기', 'showSavedReportPreview')
      .addToUi();   
}

