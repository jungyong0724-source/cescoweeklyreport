/**
 * [날짜 엔진] 2026년 기준 전년 동요일(364일 전) 및 MTD 계산
 */
function getReportingPeriods() {
  const today = new Date(); 
  const dayOfWeek = today.getDay();
  const diffToLastMon = (dayOfWeek === 0 ? 6 : dayOfWeek - 1) + 7;
  
  const curStart = new Date(today.getTime() - diffToLastMon * 24 * 60 * 60 * 1000);
  const curEnd = new Date(curStart.getTime() + 6 * 24 * 60 * 60 * 1000);
  
  const prevStart = new Date(curStart.getTime() - 7 * 24 * 60 * 60 * 1000);
  const prevEnd = new Date(curEnd.getTime() - 7 * 24 * 60 * 60 * 1000);
  
  const yearStart = new Date(curStart.getTime() - 364 * 24 * 60 * 60 * 1000);
  const yearEnd = new Date(curEnd.getTime() - 364 * 24 * 60 * 60 * 1000);

  const mtdStart = new Date(curEnd.getFullYear(), curEnd.getMonth(), 1);
  const mtdOldStart = new Date(mtdStart.getTime() - 364 * 24 * 60 * 60 * 1000);

  const f = (d) => Utilities.formatDate(d, "GMT+9", "yyyy-MM-dd");
  const fbq = (d) => Utilities.formatDate(d, "GMT+9", "yyyyMMdd");

  return {
    cur: { start: f(curStart), end: f(curEnd), bq: fbq(curStart), bqEnd: fbq(curEnd) },
    prev: { start: f(prevStart), end: f(prevEnd), bq: fbq(prevStart), bqEnd: fbq(prevEnd) },
    year: { start: f(yearStart), end: f(yearEnd), bq: fbq(yearStart), bqEnd: fbq(yearEnd) },
    mtd: { start: f(mtdStart), end: f(curEnd) },
    mtdYear: { start: f(mtdOldStart), end: f(yearEnd) }
  };
}

/**
 * [데이터 엔진] 수치 합산 로직
 */
function getPeriodStatsExtended(sheet, startStr, endStr) {
  const data = sheet.getDataRange().getValues();
  let res = { 
    total:0, webDbInclKakao:0, emergency:0, webEmSum:0, callIb:0,
    home:0, rest:0, biz:0, etc:0, 
    avgTemp:0, urgencyIndex:0, trendPest:0, issues:[], count:0 
  };

  for (let i = 1; i < data.length; i++) {
    if (!data[i][0]) continue;
    let dStr = (data[i][0] instanceof Date) ? Utilities.formatDate(data[i][0], "GMT+9", "yyyy-MM-dd") : String(data[i][0]);
    if (dStr >= startStr && dStr <= endStr) {
      let dailyWebWithKakao = Number(data[i][5]||0) + Number(data[i][17]||0) + Number(data[i][18]||0);
      let dailyEmergency = Number(data[i][20]||0) + Number(data[i][21]||0);
      
      res.webDbInclKakao += dailyWebWithKakao;
      res.emergency += dailyEmergency;
      res.webEmSum += (dailyWebWithKakao + dailyEmergency);
      res.callIb += Number(data[i][10]||0);
      res.total += Number(data[i][11]||0);

      res.home += (Number(data[i][1]||0) + Number(data[i][6]||0) + Number(data[i][17]||0) + Number(data[i][20]||0));
      res.rest += (Number(data[i][2]||0) + Number(data[i][7]||0) + Number(data[i][18]||0)); // data[i][21] 제거
      res.biz  += (Number(data[i][3]||0) + Number(data[i][8]||0) + Number(data[i][21]||0)); // data[i][21] 추가
      res.etc  += (Number(data[i][4]||0) + Number(data[i][9]||0));

      res.avgTemp += Number(data[i][14]||0); 
      res.trendPest += Number(data[i][25]||0);
      res.urgencyIndex += Number(data[i][19]||0);
      if (data[i][31]) res.issues.push(data[i][31]);
      res.count++;
    }
  }
  if(res.count > 0) {
    res.avgTemp = (res.avgTemp / res.count).toFixed(1);
    res.urgencyIndex = (res.urgencyIndex / res.count).toFixed(2);
    res.trendPest = (res.trendPest / res.count).toFixed(1);
  }
  res.issues = [...new Set(res.issues)].join(" / ");
  return res;
}

/**
 * [Main] 보고서 작성 및 시트 출력
 */
function generateWeeklyReport() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const dataSheet = ss.getSheetByName('2_로데이터');
  const ga4InboundSheet = ss.getSheetByName('GA4유입키워드');
  const ga4SearchSheet = ss.getSheetByName('GA4검색어');
  const gscSheet = ss.getSheetByName('구글서치콘솔');
  let reportSheet = ss.getSheetByName('보고시트') || ss.insertSheet('보고시트');
  
  const d = getReportingPeriods();
  
  // 1. 데이터 집계
  const cur = getDetailedStats(dataSheet, d.cur.start, d.cur.end);
  const pre = getDetailedStats(dataSheet, d.prev.start, d.prev.end);
  const old = getDetailedStats(dataSheet, d.year.start, d.year.end);
  const mtd = getDetailedStats(dataSheet, d.mtd.start, d.mtd.end);
  const mtdOld = getDetailedStats(dataSheet, d.mtdYear.start, d.mtdYear.end);
  
  // 2. 키워드/뉴스 추출
  const topInbound = extractKeywordSummary(ga4InboundSheet, 30, "유입");
  const topGSC = extractKeywordSummary(gscSheet, 10, "구글검색");
  const newsList = fetchRelatedNews(d.cur.start, d.cur.end);
  const newsContext = newsList.length > 0 ? newsList.map(n => `[${n.date}] ${n.title}`).join(" / ") : "없음";

  // 4. 시트 내 수치 데이터 작성
  reportSheet.clear();
  const pctCalc = (c, p) => p > 0 ? ((c-p)/p*100).toFixed(1) + "%" : "0.0%";

  reportSheet.getRange("B2").setValue("1. 전년 대비 월간 누적 수치 비교 (MTD)").setFontWeight("bold").setFontSize(12);
  const tableHeader = [["구분", "홈페이지 DB(카카오 포함)", "긴급진단", "홈페이지+긴급 합계", "IB 콜", "전체 신청(L)"]];
  const table1Data = [
    ["당월 누적", mtd.webDbInclKakao, mtd.emergency, mtd.webEmSum, mtd.callIb, mtd.total],
    ["전년 누적", mtdOld.webDbInclKakao, mtdOld.emergency, mtdOld.webEmSum, mtdOld.callIb, mtdOld.total],
    ["증감(%)", pctCalc(mtd.webDbInclKakao, mtdOld.webDbInclKakao), pctCalc(mtd.emergency, mtdOld.emergency), pctCalc(mtd.webEmSum, mtdOld.webEmSum), pctCalc(mtd.callIb, mtdOld.callIb), pctCalc(mtd.total, mtdOld.total)]
  ];
  reportSheet.getRange("B3:G3").setValues(tableHeader).setBackground("#0b5394").setFontColor("white").setHorizontalAlignment("center");
  reportSheet.getRange("B4:G6").setValues(table1Data).setHorizontalAlignment("center").setBorder(true, true, true, true, true, true);
  reportSheet.getRange("B6:G6").setFontWeight("bold").setFontColor("red");

  reportSheet.getRange("B8").setValue("2. 전년/전주 대비 주간 수치 비교").setFontWeight("bold").setFontSize(12);
  const table2Data = [
    [`금주 (${d.cur.start})`, cur.webDbInclKakao, cur.emergency, cur.webEmSum, cur.callIb, cur.total],
    [`전년 동요일 (${d.year.start})`, old.webDbInclKakao, old.emergency, old.webEmSum, old.callIb, old.total],
    ["전년 대비 (%)", pctCalc(cur.webDbInclKakao, old.webDbInclKakao), pctCalc(cur.emergency, old.emergency), pctCalc(cur.webEmSum, old.webEmSum), pctCalc(cur.callIb, old.callIb), pctCalc(cur.total, old.total)],
    [`전주 (${d.prev.start})`, pre.webDbInclKakao, pre.emergency, pre.webEmSum, pre.callIb, pre.total],
    ["전주 대비 (%)", pctCalc(cur.webDbInclKakao, pre.webDbInclKakao), pctCalc(cur.emergency, pre.emergency), pctCalc(cur.webEmSum, pre.webEmSum), pctCalc(cur.callIb, pre.callIb), pctCalc(cur.total, pre.total)]
  ];
  reportSheet.getRange("B9:G9").setValues(tableHeader).setBackground("#0b5394").setFontColor("white").setHorizontalAlignment("center");
  reportSheet.getRange("B10:G14").setValues(table2Data).setHorizontalAlignment("center").setBorder(true, true, true, true, true, true);

  // 5. AI 분석 리포트 생성
  const prompt = `당신은 세스코 시니어 전략 마케터입니다. 아래 데이터를 바탕으로 [전주 대비(WoW)]와 [전년 동요일 대비(YoY)] 성과 인과관계를 항목별(가~라)로 상세히 분석하세요.

    [작성 규칙] 
    1. HTML 전용: 마크다운(**) 금지. <b>, <br>, <p> 태그만 사용.
    2. 전주 및 전년 분석 비중을 1:1로 하여 매우 상세히 작성할 것.
    3. 데이터에 기반하여 단정적인 어조(~입니다)로 작성할 것.
    - 브랜드(세스코) 키워드뿐만 아니라 해충, 비용, 비즈니스위생, 이사, 비교 검색 수요의 변화를 성과와 연결하세요.
    - 예: "이사방역 트렌드가 급증한 것이 GA4 유입상세의 특정 경로 성과와 인과관계가 있는지" 등을 분석.
    4. 주요한 인사이트에는 데이터값을 인용하세요.

    [데이터 출처 엄격 분리 규칙]

    각 항목은 아래 데이터만 사용하여 작성합니다.

    가. 외부현황 → 실적, 기온, 뉴스, 공휴일
    나. 유입채널 → GA4 유입상세, (organic)값에 대한 상세 내용은 GSC 검색클릭으로 추가분석
    다. 네이버트렌드 → 네이버 키워드 트렌드 지수
    라. 기타 → 내부이슈

    다른 항목의 데이터를 절대 인용하지 마십시오.
    데이터 출처가 다른 경우 해당 내용은 작성하지 않습니다.
    
    
    - 업종별현황 항목에서는 반드시 아래 데이터만 사용하여 분석합니다.
      * 통합 업종(가정/요식/사업체) 실적 수치
      * 긴급도(T) 지표
      * 평균기온 (외부환경 보조지표로만 사용 가능)

    - 업종별현황에서는 반드시 아래 내용을 포함합니다.
      1) 업종별 증감률(금주 vs 전주 / 금주 vs 전년) 수치 기반 인과관계
      2) 업종 간 비중 이동 여부
        예: "가정 비중 확대, 사업체 축소 구조입니다."
      3) 긴급도(T)와 업종 간 상관관계
      4) 해충/이사/비즈니스위생 수요와 업종 연결 논리

    - 업종 항목에서는 네이버트렌드, GA4, GSC 데이터를 인용하지 마십시오.
    - 업종 분석은 반드시 최소 3개 단락 이상으로 매우 상세히 작성합니다.
    
    [핵심 비즈니스 로직: 중요]
    - 세스코 고객센터는 공휴일에 휴무입니다. 
    - 공휴일 변수: 세스코 고객센터는 공휴일에 휴무입니다. 
    - 만약 비교 기간 중 "공휴일"이 포함되어 유입콜(IB)이 전주나 전년 대비 하락했다면, 이를 가장 먼저 언급하여 실적 왜곡을 바로잡으세요.
    - 예: "금주는 전년 동요일 대비 공휴일(${cur.holidayCount}일 vs ${old.holidayCount}일) 영향으로 유입콜이 물리적으로 감소했으나, 홈페이지 신청은 견조합니다."

    [핵심 분석 데이터]
    - 기간: 금주(${d.cur.start} ~ ${d.cur.end}), 전주(${d.prev.start}), 전년(${d.year.start})
    - 전체 실적: 금주(${cur.total}건) / 전주(${pre.total}건) / 전년(${old.total}건)
    - 통합 업종(가정/요식/사업체): 
        * 금주: ${cur.home} / ${cur.rest} / ${cur.biz}
        * 전주: ${pre.home} / ${pre.rest} / ${pre.biz}
        * 전년: ${old.home} / ${old.rest} / ${old.biz}
    - 긴급도(T): 금주(${cur.urgencyIndex}) / 전주(${pre.urgencyIndex}) / 전년(${old.urgencyIndex})
    - 환경 지표: 
        * 평균 기온: 금주 ${cur.avgTemp}도 (전주: ${pre.avgTemp}도, 전년: ${old.avgTemp}도)
        * 네이버 키워드 지수 (금주 | 전주차 | 전년차):
      - 네이버 키워드 트렌드 지수:
        - 브랜드(세스코): 금주(${cur.trendCesco}) / 전주(${pre.trendCesco}) / 전년(${old.trendCesco})
        - 일반해충: 금주(${cur.trendPest}) / 전주(${pre.trendPest}) / 전년(${old.trendPest})
        - 방역비용: 금주(${cur.trendCost}) / 전주(${pre.trendCost}) / 전년(${old.trendCost})
        - 비즈니스위생: 금주(${cur.trendBiz}) / 전주(${pre.trendBiz}) / 전년(${old.trendBiz})
        - 이사방역: 금주(${cur.trendMoving}) / 전주(${pre.trendMoving}) / 전년(${old.trendMoving})
        - 방역경쟁사: 금주(${cur.trendComp}) / 전주(${pre.trendComp}) / 전년(${old.trendComp})
    - 외부 이슈 뉴스: ${newsContext}
    - GA4 유입상세(유입변동량): ${topInbound}
    - GSC 검색클릭: ${topGSC}
    - 내부이슈/공휴일: ${cur.issues} / ${cur.holidays || "없음"}

    [목차 – 엄격 준수]

    1. 전주 대비(WoW) 성과 인과관계 상세 분석
      가. 업종별현황
      나. 외부현황
      다. 유입채널
      라. 네이버트렌드
      마. 기타

    2. 전년 대비(YoY) 성과 인과관계 상세 분석
      가. 업종별현황
      나. 외부현황
      다. 유입채널
      라. 네이버트렌드
      마. 기타

    3. 긴급도 지표(T) 진단 및 전략 제언

    ※ 반드시 위 순서와 항목명을 그대로 사용하여 작성하십시오.
    ※ 항목을 생략하거나 합치지 마십시오.

  `;

  const aiContent = callGemini(prompt).replace(/\*\*/g, ""); 
  const finalHtml = getEmailTemplate(d, cur, pre, old, mtd, mtdOld, aiContent, newsList);

  reportSheet.getRange("B29").setValue("▼ 아래 HTML 소스를 복사하여 메일에 사용하세요").setFontWeight("bold");
  reportSheet.getRange("B30").setValue(finalHtml);

  showSavedReportPreview();
}


/**
 * [BigQuery] GA4 핵심페이지 유입분석 (8개 컬럼 복구 및 에러 해결)
 */
/**
 * [업그레이드] GA4 핵심페이지 유입분석 (소스/매체/SM별 합산 기능 추가)
 */
/**
 * [안정성 강화 버전] GA4 유입분석 (소스/매체/키워드별 합산 포함)
 */
/**
 * [오류 수정 버전] GA4 유입분석 (Null 값 방어 로직 추가)
 */
function updateGA4InboundWeeklyData(dates) {
  if (!dates) dates = getReportingPeriods();

  // IFNULL을 사용하여 소스나 매체가 없을 경우 '(direct)'나 '(none)'으로 치환하여 Null 에러를 방지합니다.
  const sql = `
    WITH session_raw AS (
      SELECT 
        user_pseudo_id,
        (SELECT value.int_value FROM UNNEST(event_params) WHERE key = 'ga_session_id') as session_id,
        traffic_source.source, 
        traffic_source.medium, 
        COALESCE((SELECT value.string_value FROM UNNEST(event_params) WHERE key = 'term'), CONCAT('(', traffic_source.medium, ')')) as keyword,
        CASE 
          WHEN _TABLE_SUFFIX BETWEEN '${dates.cur.bq}' AND '${dates.cur.bqEnd}' THEN 'cur'
          WHEN _TABLE_SUFFIX BETWEEN '${dates.prev.bq}' AND '${dates.prev.bqEnd}' THEN 'prev'
          WHEN _TABLE_SUFFIX BETWEEN '${dates.year.bq}' AND '${dates.year.bqEnd}' THEN 'year'
        END as period,
        MAX(CASE WHEN EXISTS (SELECT 1 FROM UNNEST(event_params) WHERE key = 'page_location' AND (value.string_value LIKE '%estimate%' OR value.string_value LIKE '%G2000001274%')) THEN 1 ELSE 0 END) as is_target
      FROM \`${GA4_PROJECT_ID}.${GA4_DATASET_ID}.events_*\`
      WHERE _TABLE_SUFFIX BETWEEN '${dates.year.bq}' AND '${dates.cur.bqEnd}'
      GROUP BY 1, 2, 3, 4, 5, 6
    ),
    agg_base AS (
      -- 1. 기본 로우 단위
      SELECT source, medium, keyword, period, COUNT(DISTINCT IF(is_target=1, CONCAT(user_pseudo_id, CAST(session_id AS STRING)), NULL)) as vol
      FROM session_raw WHERE period IS NOT NULL GROUP BY 1, 2, 3, 4
      UNION ALL
      -- 2. 소스별 합계 (IFNULL 추가)
      SELECT source, '(전체)', CONCAT('★[소스합계] ', IFNULL(source, '(direct)')), period, COUNT(DISTINCT IF(is_target=1, CONCAT(user_pseudo_id, CAST(session_id AS STRING)), NULL)) as vol
      FROM session_raw WHERE period IS NOT NULL GROUP BY 1, 2, 3, 4
      UNION ALL
      -- 3. 매체별 합계 (IFNULL 추가)
      SELECT '(전체)', medium, CONCAT('★[매체합계] ', IFNULL(medium, '(none)')), period, COUNT(DISTINCT IF(is_target=1, CONCAT(user_pseudo_id, CAST(session_id AS STRING)), NULL)) as vol
      FROM session_raw WHERE period IS NOT NULL GROUP BY 1, 2, 3, 4
      UNION ALL
      -- 4. 소스/매체별 합계 (IFNULL 추가)
      SELECT source, medium, CONCAT('★[S/M합계] ', IFNULL(source, '(direct)'), ' / ', IFNULL(medium, '(none)')), period, COUNT(DISTINCT IF(is_target=1, CONCAT(user_pseudo_id, CAST(session_id AS STRING)), NULL)) as vol
      FROM session_raw WHERE period IS NOT NULL GROUP BY 1, 2, 3, 4
    )
    SELECT 
      source, medium, keyword,
      SUM(IF(period = 'cur', vol, 0)) as cur_vol,
      SUM(IF(period = 'prev', vol, 0)) as prev_vol,
      SUM(IF(period = 'year', vol, 0)) as year_vol
    FROM agg_base
    GROUP BY 1, 2, 3
    HAVING cur_vol > 0 OR prev_vol > 0 OR year_vol > 0
    ORDER BY cur_vol DESC
    LIMIT 1000
  `;

  try {
    const results = runBQQuery(sql, GA4_PROJECT_ID);
    let sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('GA4유입키워드') || SpreadsheetApp.getActiveSpreadsheet().insertSheet('GA4유입키워드');
    
    sheet.clear(); 
    sheet.getRange(1,1,1,8).setValues([["소스","매체","핵심유입경로","보고주","전주","전년동기","WoW증감","YoY증감"]]);
    sheet.getRange(1,1,1,8).setBackground("#0b5394").setFontColor("white").setFontWeight("bold");

    if (results && results.length > 0) {
      const finalResults = results.map(r => {
        const c = Number(r[3] || 0);
        const p = Number(r[4] || 0);
        const y = Number(r[5] || 0);
        return [r[0], r[1], r[2], c, p, y, (c - p), (c - y)];
      });
      
      sheet.getRange(2, 1, finalResults.length, 8).setValues(finalResults);
      
      // [수정] 합계 행 배경색 강조 시 Null 체크 강화
      for(let i=0; i < finalResults.length; i++) {
        const keywordCell = finalResults[i][2];
        // keywordCell이 존재하고(null이 아니고), 문자열에 ★이 포함되어 있는지 확인
        if(keywordCell && String(keywordCell).indexOf("★") !== -1) {
          sheet.getRange(i+2, 1, 1, 8).setBackground("#f8f9fa");
        }
      }
      SpreadsheetApp.getUi().alert("GA4 유입 분석 업데이트가 완료되었습니다.");
    } else {
      SpreadsheetApp.getUi().alert("데이터가 없습니다.");
    }
  } catch (e) {
    SpreadsheetApp.getUi().alert("오류 발생: " + e.message);
  }
}

/**
 * [V15.7] 상세 데이터 집계 엔진 - 날짜 인식 및 기온 계산 정확도 강화
 */
function getDetailedStats(sheet, startStr, endStr) {
  const data = sheet.getDataRange().getValues();
  let res = { 
    total:0, webDbInclKakao:0, emergency:0, webEmSum:0, callIb:0, home:0, rest:0, biz:0,
    avgTemp:0, urgencyIndex:0, 
    trendCesco:0, trendPest:0, trendCost:0, trendBiz:0, trendMoving:0, trendComp:0,
    issues:[], holidays:[], holidayCount:0, count:0, tempCount:0 
  };

  for (let i = 1; i < data.length; i++) {
    let rawDate = data[i][0];
    if (!rawDate) continue;

    // [핵심 수정] 시트의 날짜 형식을 yyyy-MM-dd 문자열로 강제 변환 (정규화)
    let dStr = "";
    try {
      if (rawDate instanceof Date) {
        dStr = Utilities.formatDate(rawDate, "GMT+9", "yyyy-MM-dd");
      } else {
        // 숫자만 추출해서 yyyy-MM-dd로 재구성 (2025.01.27 등 텍스트 대응)
        let clean = String(rawDate).replace(/[^0-9]/g, ""); 
        if (clean.length >= 8) {
          dStr = clean.substring(0,4) + "-" + clean.substring(4,6) + "-" + clean.substring(6,8);
        }
      }
    } catch(e) { continue; }

    // 정규화된 날짜로 기간 비교
    if (dStr >= startStr && dStr <= endStr) {
      res.callIb += Number(data[i][10]||0); 
      res.total += Number(data[i][11]||0);
      res.webDbInclKakao += (Number(data[i][5]||0) + Number(data[i][17]||0) + Number(data[i][18]||0));
      res.emergency += (Number(data[i][20]||0) + Number(data[i][21]||0));
      res.webEmSum += (Number(data[i][5]||0) + Number(data[i][17]||0) + Number(data[i][18]||0) + Number(data[i][20]||0) + Number(data[i][21]||0));
      
      res.home += (Number(data[i][1]||0) + Number(data[i][6]||0) + Number(data[i][17]||0) + Number(data[i][20]||0));
      res.rest += (Number(data[i][2]||0) + Number(data[i][7]||0) + Number(data[i][18]||0)); // data[i][21] 제거
      res.biz  += (Number(data[i][3]||0) + Number(data[i][8]||0) + Number(data[i][21]||0)); // data[i][21] 추가

      // 기온 데이터가 있는 경우만 합산 (빈 셀 0도 처리 방지)
      if (data[i][14] !== "" && !isNaN(data[i][14])) {
        res.avgTemp += Number(data[i][14]);
        res.tempCount++;
      }
      
      res.urgencyIndex += Number(data[i][19]||0);
      res.trendCesco += Number(data[i][24]||0);
      res.trendPest  += Number(data[i][25]||0);
      res.trendCost  += Number(data[i][26]||0);
      res.trendBiz   += Number(data[i][27]||0);
      res.trendMoving += Number(data[i][28]||0);
      res.trendComp   += Number(data[i][29]||0);
      
      if (data[i][30] && String(data[i][30]).trim() !== "") {
        res.holidays.push(data[i][30]);
        res.holidayCount++;
      }
      if (data[i][31]) res.issues.push(data[i][31]);
      res.count++;
    }
  }
  
  if(res.count > 0) {
    // 기온은 실제 데이터가 기록된 날짜 수로 나눔
    res.avgTemp = res.tempCount > 0 ? (res.avgTemp / res.tempCount).toFixed(1) : "0.0";
    res.urgencyIndex = (res.urgencyIndex / res.count).toFixed(2);
    ["trendCesco", "trendPest", "trendCost", "trendBiz", "trendMoving", "trendComp"].forEach(k => {
      res[k] = (res[k] / res.count).toFixed(1);
    });
  }
  res.holidays = [...new Set(res.holidays)].join(", ");
  res.issues = [...new Set(res.issues)].join(" / ");
  return res;
}





/**
 * [키워드 엔진] 각 시트별 요약 정보 생성
 */
function extractKeywordSummary(sheet, limit, type) {
  if (!sheet || sheet.getLastRow() < 2) return "데이터 없음";
  // 5를 8로 수정하여 H열까지 데이터를 가져옵니다.
  const data = sheet.getRange(2, 1, Math.min(sheet.getLastRow()-1, limit), 8).getValues(); 
  return data.map(r => {
    if (type === "유입") {
      // r[6]은 WoW증감(G열), r[7]은 YoY증감(H열)입니다.
      return `${r[2]}(클릭:${r[3]}, WoW:${r[6]||0}, YoY:${r[7]||0})`; 
    }
    return `${r[0]}(수치:${r[1]})`;
  }).join(", ");
}


/**
 * [BigQuery] GSC 주간비교
 */
/**
 * [복구/강화] 구글 서치콘솔 주간 비교 업데이트 (5개 지표 시스템)
 */
function updateGSCWeeklyData(dates) {
  if (!dates) dates = getReportingPeriods();

  const sql = `
    WITH base AS (
      SELECT 
        query, 
        clicks,
        CASE 
          WHEN data_date BETWEEN '${dates.cur.start}' AND '${dates.cur.end}' THEN 'cur'
          WHEN data_date BETWEEN '${dates.prev.start}' AND '${dates.prev.end}' THEN 'prev'
          WHEN data_date BETWEEN '${dates.year.start}' AND '${dates.year.end}' THEN 'year'
        END as period
      FROM \`${BQ_PROJECT_ID}.searchconsole_cesco.searchdata_site_impression\`
      WHERE data_date BETWEEN '${dates.year.start}' AND '${dates.cur.end}'
    )
    SELECT 
      query,
      CAST(SUM(IF(period = 'cur', clicks, 0)) AS INT64) as cur_clicks,
      CAST(SUM(IF(period = 'prev', clicks, 0)) AS INT64) as prev_clicks,
      CAST(SUM(IF(period = 'year', clicks, 0)) AS INT64) as year_clicks,
      CAST(SUM(IF(period = 'cur', clicks, 0)) - SUM(IF(period = 'prev', clicks, 0)) AS INT64) as wow_diff,
      CAST(SUM(IF(period = 'cur', clicks, 0)) - SUM(IF(period = 'year', clicks, 0)) AS INT64) as yoy_diff
    FROM base
    WHERE period IS NOT NULL
    GROUP BY 1
    HAVING cur_clicks > 0 OR prev_clicks > 0
    ORDER BY cur_clicks DESC
    LIMIT 100
  `;

  const results = runBQQuery(sql, BQ_PROJECT_ID);
  let sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('구글서치콘솔') || SpreadsheetApp.getActiveSpreadsheet().insertSheet('구글서치콘솔');
  
  sheet.clear();
  const header = [["키워드", "보고주", "전주", "전년 동기", "WoW(증감)", "YoY(증감)"]];
  sheet.getRange(1, 1, 1, 6).setValues(header).setBackground("#45818e").setFontColor("white").setFontWeight("bold");

  if (results.length > 0) {
    sheet.getRange(2, 1, results.length, 6).setValues(results);
  }
  SpreadsheetApp.getUi().alert("구글 서치콘솔 5대 지표 업데이트가 완료되었습니다.");
}

/**
 * [BigQuery] GA4 내부 검색어
 */
function updateGA4WeeklyData(dates) {
  // [핵심 추가] 메뉴에서 직접 버튼을 눌렀을 때 날짜 보따리를 자동으로 채워주는 안전장치
  if (!dates) dates = getReportingPeriods();

  const sql = `
    WITH base AS (
      SELECT 
        COALESCE((SELECT value.string_value FROM UNNEST(event_params) WHERE key = 'search_term'), 'N/A') as keyword, 
        CASE 
          WHEN _TABLE_SUFFIX BETWEEN '${dates.cur.bq}' AND '${dates.cur.bqEnd}' THEN 'cur' 
          WHEN _TABLE_SUFFIX BETWEEN '${dates.prev.bq}' AND '${dates.prev.bqEnd}' THEN 'prev' 
          WHEN _TABLE_SUFFIX BETWEEN '${dates.year.bq}' AND '${dates.year.bqEnd}' THEN 'year' 
        END as period 
      FROM \`${GA4_PROJECT_ID}.${GA4_DATASET_ID}.events_*\` 
      WHERE _TABLE_SUFFIX BETWEEN '${dates.year.bq}' AND '${dates.cur.bqEnd}' 
        AND event_name = 'view_search_results'
    ) 
    SELECT 
      keyword, 
      COUNTIF(period = 'cur') as cur, 
      COUNTIF(period = 'prev') as prev, 
      COUNTIF(period = 'year') as year, 
      (COUNTIF(period = 'cur') - COUNTIF(period = 'prev')) as wow, 
      (COUNTIF(period = 'cur') - COUNTIF(period = 'year')) as yoy 
    FROM base 
    WHERE keyword != 'N/A' 
    GROUP BY 1 
    HAVING cur > 0 OR prev > 0 
    ORDER BY cur DESC 
    LIMIT 300
  `;

  const results = runBQQuery(sql, GA4_PROJECT_ID);
  let sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('GA4검색어') || SpreadsheetApp.getActiveSpreadsheet().insertSheet('GA4검색어');
  
  sheet.clear(); 
  // 기존 6개 헤더 그대로 유지
  sheet.getRange(1,1,1,6).setValues([["내부검색어(GA4)","보고주","전주","전년동기","WoW","YoY"]]);
  sheet.getRange(1,1,1,6).setBackground("#0b5394").setFontColor("white").setFontWeight("bold");

  if (results.length > 0) {
    sheet.getRange(2,1,results.length,6).setValues(results);
  }
  
  SpreadsheetApp.getUi().alert("GA4 내부검색어 주간비교(6개 항목) 업데이트가 완료되었습니다.");
}

// 공통 함수군
function updateAllData() { const d = getReportingPeriods(); updateExternalData(); updateGSCWeeklyData(d); updateGA4WeeklyData(d); updateGA4InboundWeeklyData(d); }
function runBQQuery(sql, pId) { try { return BigQuery.Jobs.query({ query: sql, useLegacySql: false }, pId).rows?.map(row => row.f.map(col => col.v)) || []; } catch(e) { return []; } }
/**
 * [오류 수정본] Gemini API 호출 엔진 (안전성 및 예외처리 강화)
 * TypeError: Cannot read properties of undefined (reading '0') 문제를 원천 차단합니다.
 */
/**
 * [V14.1] Gemini 2.0 Flash 모델 전용 호출 엔진
 * TypeError: Cannot read properties of undefined (reading '0') 완벽 방어
 */
function callGemini(prompt) {
  // 마케터님이 지정하신 2.0 Flash 엔드포인트 사용
  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${GEMINI_API_KEY}`;
  
  const payload = {
    "contents": [{
      "parts": [{
        "text": prompt
      }]
    }],
    // 세스코 방역 관련 단어(박멸, 벌레 등)가 검열되지 않도록 모든 필터 해제
    "safetySettings": [
      { "category": "HARM_CATEGORY_HARASSMENT", "threshold": "BLOCK_NONE" },
      { "category": "HARM_CATEGORY_HATE_SPEECH", "threshold": "BLOCK_NONE" },
      { "category": "HARM_CATEGORY_SEXUALLY_EXPLICIT", "threshold": "BLOCK_NONE" },
      { "category": "HARM_CATEGORY_DANGEROUS_CONTENT", "threshold": "BLOCK_NONE" }
    ],
    "generationConfig": {
      "temperature": 0.7,
      "maxOutputTokens": 2048
    }
  };

  const options = {
    "method": "post",
    "contentType": "application/json",
    "payload": JSON.stringify(payload),
    "muteHttpExceptions": true // 에러 발생 시에도 로그를 확인하기 위해 설정
  };

  try {
    const response = UrlFetchApp.fetch(url, options);
    const resText = response.getContentText();
    const json = JSON.parse(resText);

    // 로그 확인용 (에러 발생 시 실행 기록에서 확인 가능)
    if (response.getResponseCode() !== 200) {
      console.error("Gemini API Error Response: " + resText);
      return "분석 실패: API 서버에서 에러를 반환했습니다. (키 권한 또는 할당량 확인 필요)";
    }

    // [핵심 방어] candidates 배열이 있고, 그 안에 내용이 있는지 단계별로 확인
    if (json.candidates && json.candidates.length > 0 && 
        json.candidates[0].content && 
        json.candidates[0].content.parts && 
        json.candidates[0].content.parts.length > 0) {
      
      return json.candidates[0].content.parts[0].text;
    
    } else {
      // 답변이 생성되지 않은 경우 (주로 세이프티 필터 작동 시)
      console.warn("No Candidates Found. Full JSON: " + resText);
      return "데이터 분석 실패: AI가 답변 생성을 거부했습니다. (입력 데이터 확인 필요)";
    }

  } catch (e) {
    console.error("Critical Connection Error: " + e.toString());
    return "네트워크 오류: AI 서버와 연결할 수 없습니다.";
  }
}
function showSavedReportPreview() { const h = SpreadsheetApp.getActiveSpreadsheet().getSheetByName('보고시트')?.getRange("B30").getValue(); if (h) SpreadsheetApp.getUi().showModalDialog(HtmlService.createHtmlOutput(h).setWidth(950).setHeight(850), '리포트 미리보기'); }


/**
 * [V15.1] 외부 데이터(날씨, 네이버 트렌드, 지표) 동기화 엔진
 * ReferenceError 및 SyntaxError 완벽 해결 버전
 */
/**
 * [V15.3] 외부 데이터(날씨, 트렌드, 지표) 동기화 엔진 - 날짜 매칭 버그 완벽 수정
 */
/**
 * [A방법 - 최소 수정] 외부 데이터 동기화 엔진
 * 필요한 열만 선택적으로 업데이트하여 F, K, L열의 ArrayFormula를 보호합니다.
 */
/**
 * [최종 수정] 외부 데이터 동기화 엔진
 * A열(날짜), F/K/L열(기본 지표), Q열을 건드리지 않고 필요한 열만 선택적으로 업데이트합니다.
 */
function updateExternalData() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName('2_로데이터');
  if (!sheet) { SpreadsheetApp.getUi().alert("2_로데이터 시트를 찾을 수 없습니다."); return; }

  const today = new Date();
  const last45Days = Utilities.formatDate(new Date(today.getTime() - 45 * 24 * 60 * 60 * 1000), "GMT+9", "yyyyMMdd");
  const yesterdayStr = Utilities.formatDate(new Date(today.getTime() - 24 * 60 * 60 * 1000), "GMT+9", "yyyyMMdd");
  
  const oneYearAgo = Utilities.formatDate(new Date(today.getFullYear()-1, today.getMonth(), today.getDate()-7), "GMT+9", "yyyy-MM-dd");
  const yesterdayFmt = Utilities.formatDate(new Date(today.getTime() - 24 * 60 * 60 * 1000), "GMT+9", "yyyy-MM-dd");
  
  const weatherData = fetchWeatherDataRange(last45Days, yesterdayStr);
  const naverData = fetchNaverTrendRange(oneYearAgo, yesterdayFmt);
  const holidayCal = CalendarApp.getCalendarById(HOLIDAY_CAL_ID);
  
  const lastRow = sheet.getLastRow();
  const startRow = 2;
  const numRows = lastRow - 1;
  if (numRows <= 0) return;

  // 1. [읽기] 계산을 위해 A~AI열 전체를 가져옵니다 (A, F, K, Q열 등 참조용).
  const range = sheet.getRange(startRow, 1, numRows, 35); 
  const values = range.getValues();

  let weatherCount = 0;
  let naverCount = 0;

  for (let i = 0; i < values.length; i++) {
    let rawDate = values[i][0]; // A열(index 0) 읽기
    if (!rawDate) continue;

    let dStr = "";
    try {
      if (rawDate instanceof Date) {
        dStr = Utilities.formatDate(rawDate, "GMT+9", "yyyy-MM-dd");
      } else {
        let clean = String(rawDate).replace(/[^0-9]/g, ""); 
        if (clean.length >= 8) {
          dStr = clean.substring(0,4) + "-" + clean.substring(4,6) + "-" + clean.substring(6,8);
        }
      }
    } catch(e) { continue; }

    if (dStr >= oneYearAgo) {
      // 날씨(O:14, W:22, X:23)
      const wMatch = weatherData.find(item => item.tm === dStr);
      if (wMatch) { 
        values[i][14] = wMatch.avgTa; 
        values[i][22] = wMatch.maxTa; 
        values[i][23] = wMatch.sumRn || 0; 
        weatherCount++;
      }
      // 기온차(P:15)
      if (i > 0 && values[i][14] !== "" && values[i-1][14] !== "") {
        values[i][15] = (Number(values[i][14]) - Number(values[i-1][14])).toFixed(1);
      }
      // 긴급도(T:19) - F열(5)과 K열(10) 참조
      let freeIbSum = Number(values[i][5] || 0) + Number(values[i][10] || 0);
      let emergencySum = Number(values[i][20] || 0) + Number(values[i][21] || 0);
      values[i][19] = freeIbSum > 0 ? (emergencySum / freeIbSum).toFixed(2) : 0;

      // 네이버 트렌드(Y~AD:24~29)
      const nMatch = naverData.find(item => item.period === dStr);
      if (nMatch && nMatch.ratios) {
        nMatch.ratios.forEach((r, idx) => { if (idx < 6) values[i][24 + idx] = r; });
        naverCount++;
      }
      // 공휴일(AE:30)
      if (holidayCal) {
        try {
          const events = holidayCal.getEventsForDay((rawDate instanceof Date) ? rawDate : new Date(dStr));
          values[i][30] = events.length > 0 ? events.map(h => h.getTitle()).join(", ") : "";
        } catch(e) {}
      }
    }
  }
  
  // 2. [쓰기] 보호해야 할 열(A~N, Q~S)을 제외하고 필요한 구간만 업데이트합니다.
  
  // 기온/기온차 업데이트 (O~P열, 15~16번째 열)
  sheet.getRange(startRow, 15, numRows, 2).setValues(values.map(r => [r[14], r[15]]));
  
  // Q, R, S열은 건너뜁니다.
  
  // 긴급도 지표 업데이트 (T열, 20번째 열)
  sheet.getRange(startRow, 20, numRows, 1).setValues(values.map(r => [r[19]]));
  
  // 최고기온/강수량 업데이트 (W~X열, 23~24번째 열)
  sheet.getRange(startRow, 23, numRows, 2).setValues(values.map(r => [r[22], r[23]]));
  
  // 네이버 트렌드 업데이트 (Y~AD열, 25~30번째 열)
  sheet.getRange(startRow, 25, numRows, 6).setValues(values.map(r => r.slice(24, 30)));
  
  // 공휴일 정보 업데이트 (AE열, 31번째 열)
  sheet.getRange(startRow, 31, numRows, 1).setValues(values.map(r => [r[30]]));

  SpreadsheetApp.getUi().alert(`✅ 동기화 완료! (A열 및 Q열 등 모든 수식 열이 보호되었습니다.)`);
}

function fetchWeatherDataRange(start, end) {
  const url = `http://apis.data.go.kr/1360000/AsosDalyInfoService/getWthrDataList?serviceKey=${encodeURIComponent(WEATHER_SERVICE_KEY)}&numOfRows=900&pageNo=1&dataCd=ASOS&dateCd=DAY&startDt=${start}&endDt=${end}&stnIds=108&dataType=JSON`;
  try {
    const res = UrlFetchApp.fetch(url, { "muteHttpExceptions": true });
    const resJson = JSON.parse(res.getContentText());
    return resJson.response.body.items.item || [];
  } catch (e) { console.log("Weather API Error"); return []; }
}

/**
 * [V15.4] 네이버 트렌드 데이터 수집 - 각 그룹별 개별 100 기준(정규화) 로직
 */
function fetchNaverTrendRange(start, end) {
  const url = "https://openapi.naver.com/v1/datalab/search";
  let mergedResults = [];
  
  // 각 키워드 그룹을 하나씩 독립적으로 호출 (그룹별 개별 100 기준 확보)
  for (let i = 0; i < NAVER_KEYWORD_GROUPS.length; i++) {
    const singleGroup = [NAVER_KEYWORD_GROUPS[i]];
    const payload = { 
      "startDate": start, 
      "endDate": end, 
      "timeUnit": "date", 
      "keywordGroups": singleGroup 
    };
    const options = { 
      "method": "post", "contentType": "application/json", 
      "headers": { 
        "X-Naver-Client-Id": NAVER_CLIENT_ID, 
        "X-Naver-Client-Secret": NAVER_CLIENT_SECRET 
      },
      "payload": JSON.stringify(payload), 
      "muteHttpExceptions": true 
    };

    try {
      const res = UrlFetchApp.fetch(url, options);
      const json = JSON.parse(res.getContentText());
      
      if (json.results && json.results[0].data) {
        // 첫 번째 그룹 호출 시 날짜(period) 틀 생성
        if (mergedResults.length === 0) {
          json.results[0].data.forEach(d => mergedResults.push({ period: d.period, ratios: [] }));
        }
        
        // 해당 그룹의 데이터를 날짜별로 매칭하여 ratios 배열에 추가
        json.results[0].data.forEach((d, dIdx) => {
          if (mergedResults[dIdx]) {
            mergedResults[dIdx].ratios.push(d.ratio);
          }
        });
      }
    } catch (e) {
      console.log(`${NAVER_KEYWORD_GROUPS[i].groupName} 그룹 호출 중 에러 발생`);
    }
  }
  return mergedResults;
}

/**
 * [BigQuery] 데이터 연동 공통 함수
 */
function runBQQuery(sql, projectId) {
  try {
    const queryResults = BigQuery.Jobs.query({ query: sql, useLegacySql: false }, projectId);
    return queryResults.rows ? queryResults.rows.map(row => row.f.map(col => col.v)) : [];
  } catch (e) { return []; }
}

function fetchRelatedNews(startDate, endDate) {
  const query = encodeURIComponent("세스코 OR 방역 OR 해충 OR 빈대 OR 기후변화");
  const url = `https://openapi.naver.com/v1/search/news.json?query=${query}&display=50&sort=date`;
  
  const options = {
    "headers": {
      "X-Naver-Client-Id": NAVER_CLIENT_ID,
      "X-Naver-Client-Secret": NAVER_CLIENT_SECRET
    },
    "muteHttpExceptions": true
  };

  try {
    const response = UrlFetchApp.fetch(url, options);
    const items = JSON.parse(response.getContentText()).items;
    
    // 분석 기간(월~일)에 해당하는 뉴스만 필터링
    const start = new Date(startDate + "T00:00:00");
    const end = new Date(endDate + "T23:59:59");
    
    return items
      .filter(item => {
        const pubDate = new Date(item.pubDate);
        return pubDate >= start && pubDate <= end;
      })
      .map(item => ({
        title: item.title.replace(/<[^>]*>?/gm, ''), // HTML 태그 제거
        link: item.link,
        date: Utilities.formatDate(new Date(item.pubDate), "GMT+9", "MM-dd")
      }))
      .slice(0, 8); // 상위 8개만 반환
  } catch (e) {
    console.error("News Fetch Error: " + e.toString());
    return [];
  }
}


/**
 * [복구] 고품격 리포트 UI 템플릿 (MTD/주간 비교표 및 디자인 강화)
 */
/**
 * [V15.9] 주간 비교표(Table 2)가 추가된 고품격 리포트 UI 템플릿
 */
function getEmailTemplate(d, cur, pre, old, mtd, mtdOld, aiContent, newsList) {
  const pct = (c, p) => {
    if (!p || p === 0) return "0.0%";
    const val = ((c - p) / p * 100).toFixed(1);
    const color = val >= 0 ? "#d93025" : "#1967d2"; // 상승은 빨강, 하락은 파랑
    return `<span style="color:${color}; font-weight:bold;">${val >= 0 ? '▲' : '▼'}${Math.abs(val)}%</span>`;
  };

  const newsHtml = newsList.length > 0 
    ? newsList.map(n => `<li style="margin-bottom:6px; font-size:13px;">[${n.date}] <a href="${n.link}" target="_blank" style="color:#0b5394; text-decoration:none;">${n.title}</a></li>`).join("")
    : "<li style='color:#999;'>분석 기간 내 주요 뉴스가 없습니다.</li>";

  return `
    <div style="font-family: 'Malgun Gothic', sans-serif; max-width: 800px; margin: auto; padding: 20px; border: 1px solid #eee; color: #333;">
      <header style="border-bottom: 3px solid #0b5394; padding-bottom: 10px; margin-bottom: 20px;">
        <h2 style="color: #0b5394; margin: 0;">📊 세스코 통합 마케팅 성과 분석 리포트</h2>
        <p style="margin: 5px 0 0 0; font-size: 13px; color: #666;">분석 기간: ${d.cur.start} ~ ${d.cur.end}</p>
      </header>

      <section style="margin-bottom: 30px;">
        <h4 style="background: #f8f9fa; padding: 8px; border-left: 4px solid #0b5394; margin-bottom: 10px;">1. 전년 대비 월간 누적 비교 (MTD)</h4>
        <table border="1" style="border-collapse: collapse; width: 100%; text-align: center; font-size: 12px; border-color: #ddd;">
          <tr style="background: #f3f3f3; font-weight: bold;">
            <th style="padding: 10px;">구분</th><th>홈페이지 DB<br>(카카오포함)</th><th>긴급진단</th><th>홈페이지+긴급<br>합계</th><th>IB 콜</th><th>전체 신청</th>
          </tr>
          <tr>
            <td style="padding: 10px; background: #fff;">당월 누적</td>
            <td>${mtd.webDbInclKakao}</td><td>${mtd.emergency}</td><td style="font-weight:bold;">${mtd.webEmSum}</td><td>${mtd.callIb}</td><td>${mtd.total}</td>
          </tr>
          <tr>
            <td style="padding: 10px; background: #fff;">전년 누적</td>
            <td>${mtdOld.webDbInclKakao}</td><td>${mtdOld.emergency}</td><td style="font-weight:bold;">${mtdOld.webEmSum}</td><td>${mtdOld.callIb}</td><td>${mtdOld.total}</td>
          </tr>
          <tr style="background: #fdfdfd;">
            <td style="padding: 10px; font-weight: bold;">증감(%)</td>
            <td>${pct(mtd.webDbInclKakao, mtdOld.webDbInclKakao)}</td><td>${pct(mtd.emergency, mtdOld.emergency)}</td><td>${pct(mtd.webEmSum, mtdOld.webEmSum)}</td><td>${pct(mtd.callIb, mtdOld.callIb)}</td><td>${pct(mtd.total, mtdOld.total)}</td>
          </tr>
        </table>
      </section>

      <section style="margin-bottom: 30px;">
        <h4 style="background: #f8f9fa; padding: 8px; border-left: 4px solid #0b5394; margin-bottom: 10px;">2. 전년/전주 대비 주간 수치 비교</h4>
        <table border="1" style="border-collapse: collapse; width: 100%; text-align: center; font-size: 11px; border-color: #ddd;">
          <tr style="background: #f3f3f3; font-weight: bold;">
            <th style="padding: 8px;">구분</th><th>홈페이지 DB<br>(카카오포함)</th><th>긴급진단</th><th>홈페이지+긴급<br>합계</th><th>IB 콜</th><th>전체 신청</th>
          </tr>
          <tr>
            <td style="padding: 8px; background: #fff;">금주 (${d.cur.start})</td>
            <td>${cur.webDbInclKakao}</td><td>${cur.emergency}</td><td style="font-weight:bold;">${cur.webEmSum}</td><td>${cur.callIb}</td><td>${cur.total}</td>
          </tr>
          <tr>
            <td style="padding: 8px; background: #fff;">전년 동요일 (${d.year.start})</td>
            <td>${old.webDbInclKakao}</td><td>${old.emergency}</td><td>${old.webEmSum}</td><td>${old.callIb}</td><td>${old.total}</td>
          </tr>
          <tr style="background: #fdfdfd; font-weight: bold;">
            <td style="padding: 8px;">전년 대비 (%)</td>
            <td>${pct(cur.webDbInclKakao, old.webDbInclKakao)}</td><td>${pct(cur.emergency, old.emergency)}</td><td>${pct(cur.webEmSum, old.webEmSum)}</td><td>${pct(cur.callIb, old.callIb)}</td><td>${pct(cur.total, old.total)}</td>
          </tr>
          <tr>
            <td style="padding: 8px; background: #fff;">전주 (${d.prev.start})</td>
            <td>${pre.webDbInclKakao}</td><td>${pre.emergency}</td><td>${pre.webEmSum}</td><td>${pre.callIb}</td><td>${pre.total}</td>
          </tr>
          <tr style="background: #fdfdfd; font-weight: bold;">
            <td style="padding: 8px;">전주 대비 (%)</td>
            <td>${pct(cur.webDbInclKakao, pre.webDbInclKakao)}</td><td>${pct(cur.emergency, pre.emergency)}</td><td>${pct(cur.webEmSum, pre.webEmSum)}</td><td>${pct(cur.callIb, pre.callIb)}</td><td>${pct(cur.total, pre.total)}</td>
          </tr>
        </table>
      </section>

      <section style="margin-bottom: 30px;">
        <h4 style="background: #f8f9fa; padding: 8px; border-left: 4px solid #0b5394; margin-bottom: 10px;">3. 데이터 기반 전략 인과관계 분석</h4>
        <div style="line-height: 1.8; font-size: 14px; background: #fcfcfc; padding: 20px; border-radius: 5px; border: 1px solid #eee;">
          ${aiContent}
        </div>
      </section>

      <section>
        <h4 style="background: #f8f9fa; padding: 8px; border-left: 4px solid #0b5394; margin-bottom: 10px;">4. 분석 기간 내 주요 외부 이슈</h4>
        <ul style="padding-left: 20px; margin: 0;">
          ${newsHtml}
        </ul>
      </section>

      <footer style="margin-top: 40px; padding-top: 10px; border-top: 1px solid #eee; font-size: 11px; color: #999; text-align: center;">
        본 리포트는 세스코 디지털 마케팅 대시보드 AI 엔진에 의해 자동 생성되었습니다.
      </footer>
    </div>
  `;
}

function testKey() {
  const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${GEMINI_API_KEY}`;
  const payload = { "contents": [{ "parts": [{ "text": "안녕" }] }] };
  const options = { "method": "post", "contentType": "application/json", "payload": JSON.stringify(payload), "muteHttpExceptions": true };
  
  const res = UrlFetchApp.fetch(url, options);
  const code = res.getResponseCode();
  const text = res.getContentText();
  
  if (code === 200) {
    SpreadsheetApp.getUi().alert("✅ API 키가 정상입니다! 모델도 잘 작동해요.");
  } else {
    SpreadsheetApp.getUi().alert("❌ 에러 발생! \n응답 코드: " + code + "\n상세 내용: " + text);
  }
}
